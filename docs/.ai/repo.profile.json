{
  "repo_id": "claude-code-kit",
  "package_manager": "unknown",
  "doc_roots": [
    "docs/L0_concept",
    "docs/L1_project",
    "docs/L2_development",
    "docs/L3_implementation"
  ],
  "commands": {},
  "active_commands": [
    "commands/work.md",
    "commands/task.md",
    "commands/patch.md",
    "commands/docs-sync.md",
    "commands/init-docs.md",
    "commands/review-resolve.md",
    "commands/new-issue.md",
    "commands/coding-general.md",
    "commands/coding-js.md"
  ],
  "templates": [
    "commands/templates/issue.md",
    "commands/templates/pr.md"
  ],
  "hooks": [
    "hooks/guard-destructive-cmd.sh",
    "hooks/log-token-usage.sh",
    "hooks/log-access-prompt.sh",
    "hooks/log-access-tool.sh",
    "hooks/log-access-stop.sh",
    "hooks/notify-slack.sh"
  ],
  "external_cli_deps": ["git", "gh", "jq", "curl"],
  "skills": [
    "skills/work/SKILL.md",
    "skills/task/SKILL.md",
    "skills/patch/SKILL.md",
    "skills/docs-sync/SKILL.md",
    "skills/init-docs/SKILL.md",
    "skills/new-issue/SKILL.md",
    "skills/review-resolve/SKILL.md",
    "skills/coding-general/SKILL.md",
    "skills/coding-js/SKILL.md"
  ],
  "primary_docs": {
    "investigation": "docs/L3_implementation/specification_summary.md",
    "structure": "docs/L1_project/repository_structure.md"
  },
  "deploy": {
    "commands": {
      "method": "symlink",
      "source": "commands/",
      "target": "~/.claude/commands/"
    },
    "hooks": {
      "method": "symlink",
      "source": "hooks/",
      "target": "~/.claude/hooks/"
    },
    "claude_md": {
      "method": "symlink",
      "source": "CLAUDE.md",
      "target": "~/.claude/CLAUDE.md"
    },
    "skills": {
      "method": "symlink",
      "source": "skills/",
      "target": "~/.codex/skills/"
    }
  }
}
