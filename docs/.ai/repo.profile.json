{
  "repo_id": "core-toolkit-for-claude",
  "package_manager": "npm",
  "doc_roots": [
    "docs/L0_concept",
    "docs/L1_project",
    "docs/L2_development",
    "docs/L3_implementation"
  ],
  "commands": {
    "install": "./install.sh",
    "statusline:install": "./setup_statusline.sh",
    "ci:install": "cd site && npm ci",
    "site:dev": "cd site && npm run docs:dev",
    "site:build": "cd site && npm run docs:build",
    "site:preview": "cd site && npm run docs:preview"
  },
  "active_commands": [
    "commands/work.md",
    "commands/triage-issues.md",
    "commands/new-issue.md",
    "commands/review-resolve.md",
    "commands/codex-review.md",
    "commands/task.md",
    "commands/patch.md",
    "commands/docs-sync.md",
    "commands/init-docs.md",
    "commands/coding-general.md",
    "commands/coding-py.md",
    "commands/coding-js.md",
    "commands/coding-ts.md",
    "commands/git-commit.md"
  ],
  "templates": [
    "templates/issue.md",
    "templates/pr.md",
    "templates/readme.md"
  ],
  "hooks": [
    "hooks/auto-approve-readonly.sh",
    "hooks/cleanup-session.sh",
    "hooks/guard-destructive-cmd.sh",
    "hooks/log-access-prompt.sh",
    "hooks/log-access-stop.sh",
    "hooks/log-access-tool.sh",
    "hooks/log-token-usage.sh",
    "hooks/tmux-agent-status.sh"
  ],
  "external_cli_deps": [
    "git",
    "gh",
    "jq",
    "node",
    "npm",
    "bc",
    "codex"
  ],
  "ci": {
    "workflows": [
      {
        "file": ".github/workflows/deploy.yml",
        "trigger": "push to main and workflow_dispatch",
        "runtime": "Node.js 24",
        "package_manager": "npm",
        "commands": [
          "npm ci",
          "npm run docs:build"
        ],
        "working_directory": "site",
        "purpose": "Build VitePress site in site/ and deploy site/.vitepress/dist to GitHub Pages"
      }
    ]
  },
  "site": {
    "root": "site",
    "framework": "VitePress",
    "config": "site/.vitepress/config.mts",
    "package_file": "site/package.json",
    "lock_file": "site/package-lock.json"
  },
  "skills": [
    "skills/codex-review/SKILL.md",
    "skills/work/SKILL.md",
    "skills/triage-issues/SKILL.md",
    "skills/task/SKILL.md",
    "skills/patch/SKILL.md",
    "skills/docs-sync/SKILL.md",
    "skills/init-docs/SKILL.md",
    "skills/new-issue/SKILL.md",
    "skills/review-resolve/SKILL.md",
    "skills/coding-general/SKILL.md",
    "skills/coding-py/SKILL.md",
    "skills/coding-js/SKILL.md",
    "skills/coding-ts/SKILL.md",
    "skills/git-commit/SKILL.md"
  ],
  "primary_docs": {
    "investigation": "docs/L3_implementation/specification_summary.md",
    "structure": "docs/L1_project/repository_structure.md"
  },
  "deploy": {
    "commands": {
      "method": "symlink",
      "source": "commands/",
      "target": "~/.claude/commands/"
    },
    "codex_commands": {
      "method": "symlink",
      "source": "commands/",
      "target": "~/.codex/commands/"
    },
    "hooks": {
      "method": "symlink",
      "source": "hooks/",
      "target": "~/.claude/hooks/"
    },
    "claude_md": {
      "method": "manual symlink",
      "source": "CLAUDE.md",
      "target": "~/.claude/CLAUDE.md"
    },
    "skills": {
      "method": "symlink",
      "source": "skills/",
      "target": "~/.codex/skills/"
    },
    "templates": {
      "method": "manual symlink",
      "source": "templates/",
      "target": "~/.config/claude-code-kit/templates/"
    },
    "statusline": {
      "method": "manual installer",
      "source": "scripts/statusline.sh",
      "target": "~/.claude/statusline.sh",
      "installer": "./setup_statusline.sh"
    },
    "github_pages": {
      "method": "github-actions",
      "source": "site/.vitepress/dist",
      "workflow": ".github/workflows/deploy.yml"
    },
    "codex_hooks": {
      "method": "symlink + hooks.json registration",
      "source": "hooks/",
      "target": "~/.codex/hooks/",
      "config": "~/.codex/hooks.json"
    }
  }
}
