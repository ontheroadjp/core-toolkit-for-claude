{
  "repo_id": "claude-code-kit",
  "package_manager": "unknown",
  "doc_roots": [
    "docs/L0_concept",
    "docs/L1_project",
    "docs/L2_development",
    "docs/L3_implementation"
  ],
  "commands": {},
  "active_commands": [
    "commands/task.md",
    "commands/patch.md",
    "commands/docs-sync.md",
    "commands/init-docs.md"
  ],
  "templates": [
    "commands/templates/issue.md",
    "commands/templates/pr.md"
  ],
  "hooks": [
    "hooks/log-token-usage.sh"
  ],
  "external_cli_deps": ["git", "gh", "jq"],
  "deploy": {
    "commands": {
      "method": "symlink",
      "source": "commands/",
      "target": "~/.claude/commands/"
    },
    "hooks": {
      "method": "symlink",
      "source": "hooks/",
      "target": "~/.claude/hooks/"
    },
    "claude_md": {
      "method": "symlink",
      "source": "CLAUDE.md",
      "target": "~/.claude/CLAUDE.md"
    }
  }
}
